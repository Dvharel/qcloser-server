# Django Core Settings

DJANGO_SECRET_KEY=dev-secret-change-me

DJANGO_DEBUG=True

# Hosts allowed to access Django
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

DATABASE_URL=postgres://qcloser:qcloser_password@localhost:5433/qcloser

OPENAI_API_KEY=sk-your-openai-key-here

# REQUIRED — the server will crash at startup without this key
ASSEMBLYAI_API_KEY=your-assemblyai-key-here

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Email
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@qcloser.ai

USE_S3=False

AWS_ACCESS_KEY_ID=YOUR_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_SECRET

# The bucket where call recordings + transcripts will be stored
AWS_STORAGE_BUCKET_NAME=qcloser-audio-dev

# Your AWS region
AWS_S3_REGION_NAME=eu-central-1

# Controls expiry (seconds) of pre-signed URLs returned by audio_file.url in API responses (django-storages setting)
AWS_QUERYSTRING_EXPIRE=3600

# Controls expiry (seconds) of pre-signed URLs generated for AssemblyAI transcription submissions (our setting)
AWS_S3_PRESIGNED_EXPIRY=3600
